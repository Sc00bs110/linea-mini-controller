// secrets.h.example -- template for compile-time credentials.
//
// Copy this file to include/secrets.h and fill in real values.
// include/secrets.h is gitignored and must never be committed.
//
// Keys below are the exact identifiers the ported firmware modules reference
// from secrets.h (derived from W:\LM_Mini.git: wifi_config.cpp, mqtt.cpp,
// main.cpp). WiFi credentials here act as a compile-time fallback when NVS has
// no saved network; MQTT_USER/MQTT_PASS and OTA_PASSWORD may be left empty
// strings if the broker/OTA are unauthenticated.
#pragma once

// -- WiFi (fallback when no NVS-stored credentials) --
#define WIFI_SSID       "your-wifi-ssid"
#define WIFI_PASSWORD   "your-wifi-password"

// -- MQTT broker --
// MQTT_HOST is intentionally EMPTY in this template. Broker config is stored in
// NVS (namespace "mqttcfg") after the first flash of a locally-built image, and
// survives OTA updates. A CI-built image ships with these defines blank so it
// never overwrites the device's saved broker with a bogus host — an empty host
// simply leaves MQTT disabled. For a local build, set MQTT_HOST to your broker.
#define MQTT_HOST       ""
#define MQTT_PORT       1883
#define MQTT_USER       ""
#define MQTT_PASS       ""

// -- Arduino OTA (empty string disables the OTA password) --
#define OTA_PASSWORD    ""
